# ═══════════════════════════════════════════════════════════════
# Nitpickers Environment Configuration
# ═══════════════════════════════════════════════════════════════
#
# Copy this file to .env or .nitpick/.env to apply locally.
# .nitpick/.env is gitignored and loaded by _load_env() in config.py
# with strict prefix filtering for security.
#
# Priority: os.environ > .env > .nitpick/.env

# ── Tier A: Secret Tier ───────────────────────────────────────
# These MUST NOT be committed to version control.

# Core API Keys
JULES_API_KEY=your_jules_key
E2B_API_KEY=your_e2b_key
OPENROUTER_API_KEY=your_openrouter_key

# Observability / LangSmith Tracing
# You can use either LANGCHAIN_* or LANGSMITH_* variable names.
# The project will sync between them automatically.
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_key
LANGCHAIN_PROJECT=nitpickers
# LANGSMITH_API_KEY=your_langsmith_key  # alternative to LANGCHAIN_API_KEY

# ── Tier B: Tuning Tier ───────────────────────────────────────
# These can be placed in .nitpick/.env for project-level overrides.
# They are also managed in docker-compose.yml for Docker users.
#
# NITPICK_AUDITOR_MODEL=openai:gpt-4o
# NITPICK_REVIEWER__SMART_MODEL=openai:gpt-4o
# NITPICK_NUM_AUDITORS=3
# NITPICK_REVIEWS_PER_AUDITOR=2
# NITPICK_MAX_ITERATIONS=3
